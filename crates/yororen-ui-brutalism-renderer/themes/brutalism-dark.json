{
  "surface": {
    "base": "#0A0A0A",
    "canvas": "#000000",
    "raised": "#141414",
    "sunken": "#050505",
    "hover": "#1F1F1F"
  },
  "content": {
    "primary": "#FFFFFF",
    "secondary": "#E5E5E5",
    "tertiary": "#B2B2B2",
    "disabled": "#666666",
    "on_primary": "#000000",
    "on_status": "#000000"
  },
  "border": {
    "default": "#FFFFFF",
    "muted": "#FFFFFF",
    "focus": "#FF3366",
    "divider": "#FFFFFF"
  },
  "action": {
    "neutral": {
      "bg": "#141414",
      "hover_bg": "#FFFF00",
      "active_bg": "#00FFFF",
      "fg": "#FFFFFF",
      "disabled_bg": "#1F1F1F",
      "disabled_fg": "#666666"
    },
    "primary": {
      "bg": "#FFFFFF",
      "hover_bg": "#FF3366",
      "active_bg": "#FFFF00",
      "fg": "#000000",
      "disabled_bg": "#333333",
      "disabled_fg": "#999999"
    },
    "danger": {
      "bg": "#FF0033",
      "hover_bg": "#FFFFFF",
      "active_bg": "#FFFF00",
      "fg": "#FFFFFF",
      "disabled_bg": "#3D0A0A",
      "disabled_fg": "#996666"
    }
  },
  "status": {
    "neutral":  { "bg": "#000000", "fg": "#FFFFFF" },
    "success":  { "bg": "#00FF66", "fg": "#000000" },
    "warning":  { "bg": "#FFCC00", "fg": "#000000" },
    "danger":   { "bg": "#FF0033", "fg": "#FFFFFF" },
    "error":    { "bg": "#FF0033", "fg": "#FFFFFF" },
    "info":     { "bg": "#00CCFF", "fg": "#000000" }
  },
  "shadow": {
    "default": { "offset_x": 4, "offset_y": 4, "blur": 0, "spread": 0, "color": "#FFFFFF" },
    "raised":  { "offset_x": 6, "offset_y": 6, "blur": 0, "spread": 0, "color": "#FFFFFF" },
    "overlay": { "offset_x": 8, "offset_y": 8, "blur": 0, "spread": 0, "color": "#FFFFFF" }
  },
  "tokens": {
    "radii": { "none": 0, "xs": 0, "sm": 0, "md": 0, "lg": 0, "xl": 0, "pill": 0 },
    "spacing": { "tight": 4, "normal": 8, "loose": 16 },
    "typography": {
      "family_default": "ui-monospace, 'Courier New', monospace",
      "family_mono": "ui-monospace, 'Courier New', monospace",
      "font_size_xxs": 11, "font_size_xs": 12, "font_size_sm": 13,
      "font_size_md": 14, "font_size_lg": 16, "font_size_xl": 20,
      "font_size_xxl": 28, "font_size_xxxl": 40,
      "weight_normal": 400, "weight_medium": 700, "weight_bold": 800
    },
    "motion": { "duration_fast": 0, "duration_normal": 0, "duration_slow": 0 },
    "control": {
      "button": { "min_height": 44, "horizontal_padding": 20, "vertical_padding": 12, "radius": 0, "border_width": 3 },
      "icon_button": { "size": 44, "radius": 0, "border_width": 3 },
      "toggle_button": { "min_height": 44, "horizontal_padding": 16, "radius": 0, "border_width": 3 },
      "split_button": { "min_height": 44, "radius": 0, "border_width": 3 },
      "label": { "font_size": 14, "weight": 700 },
      "heading": { "font_size_lg": 32, "font_size_md": 24, "font_size_sm": 20, "weight": 800 },
      "divider": { "thickness": 2 },
      "focus_ring": { "width": 4, "offset": 0, "color": "#FF3366" },
      "badge": { "min_height": 22, "horizontal_padding": 8, "vertical_padding": 2, "radius": 0, "border_width": 2, "font_size": 11, "weight": 800 },
      "tag": { "min_height": 28, "horizontal_padding": 12, "vertical_padding": 6, "radius": 0, "border_width": 2 },
      "progress": { "height": 28, "radius": 0, "border_width": 2 },
      "skeleton": { "radius": 0, "border_width": 2 },
      "tooltip": { "radius": 0, "border_width": 2, "padding_x": 10, "padding_y": 6, "font_size": 12 },
      "avatar": { "size": 40, "radius": 0, "border_width": 2 },
      "switch": { "track_w": 52, "track_h": 30, "knob_size": 22, "radius": 0, "border_width": 3 },
      "checkbox": { "size": 24, "radius": 0, "border_width": 3 },
      "radio": { "size": 24, "radius": 0, "border_width": 3 },
      "input": { "min_height": 42, "horizontal_padding": 12, "vertical_padding": 10, "radius": 0, "border_width": 3, "font_size": 14 },
      "select": { "min_height": 42, "horizontal_padding": 12, "radius": 0, "border_width": 3 },
      "combo_box": { "min_height": 42, "radius": 0, "border_width": 3 },
      "number_input": { "min_height": 42, "radius": 0, "border_width": 3 },
      "file_path_input": { "min_height": 42, "radius": 0, "border_width": 3 },
      "search_input": { "min_height": 42, "radius": 0, "border_width": 3 },
      "password_input": { "min_height": 42, "radius": 0, "border_width": 3 },
      "keybinding_input": { "min_height": 42, "radius": 0, "border_width": 3 },
      "text_area": { "min_height": 90, "padding": 12, "radius": 0, "border_width": 3, "font_size": 14 },
      "modal": { "radius": 0, "border_width": 4, "padding": 24, "title_size": 24 },
      "popover": { "radius": 0, "border_width": 3, "padding": 12 },
      "dropdown_menu": { "radius": 0, "border_width": 3, "padding": 4 },
      "disclosure": { "radius": 0, "border_width": 2 },
      "toast": { "radius": 0, "border_width": 3, "padding": 12 },
      "notification": { "radius": 0, "border_width": 3, "padding": 16 },
      "panel": { "radius": 0, "border_width": 3, "padding": 16 },
      "card": { "radius": 0, "border_width": 3, "padding": 16 },
      "form": { "radius": 0, "border_width": 0, "padding": 16, "gap": 12 },
      "list_item": { "radius": 0, "border_width": 2, "padding": 10, "min_height": 36 },
      "tree_item": { "radius": 0, "border_width": 2, "padding": 8, "min_height": 32 },
      "empty_state": { "radius": 0, "border_width": 3, "padding": 32 }
    }
  }
}
