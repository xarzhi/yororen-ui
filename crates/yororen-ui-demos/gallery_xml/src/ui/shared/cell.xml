<!-- Shared Cell / InputCell templates used by section files. -->
<Fragment>
    <Template name="Cell">
        <Div flex flex_col items_start gap="4" p="8" rounded_md border_1
             border_color={gpui::hsla(0.0, 0.0, 0.5, 0.15)}>
            <Slot name="label" />
            <Slot />
        </Div>
    </Template>

    <Template name="InputCell">
        <Div flex flex_col gap="4" p="8" rounded_md border_1
             border_color={gpui::hsla(0.0, 0.0, 0.5, 0.15)}>
            <Slot name="name" />
            <Slot />
            <Slot name="status" />
        </Div>
    </Template>
</Fragment>
