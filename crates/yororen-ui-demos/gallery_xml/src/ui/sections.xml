<!-- Top-level section virtual list. Each direct child is one
     row, and `item_count` is derived from the number of
     children — no Rust glue, no `controller.section_element`.
     Off-screen rows are never built (gpui's `list()` only
     invokes the per-visible-index closure). The
     VirtualListController is auto-persisted by the engine via
     `window.use_keyed_state(id, …)`, so the host view carries
     no controller field.

     The shared cell / section templates are included at the root
     level (sibling to the VirtualList) so they are registered once
     at compile time and are never re-evaluated as part of a virtual
     row. Standard rows use the shared `<Section>` template, which
     applies the modest 16-px `p="4"` inset without repeating the
     wrapper on every line. -->
<Fragment>
    <Include src="ui/shared/cell.xml" />
    <Include src="ui/shared/section.xml" />

    <VirtualList id="gallery-sections" size_full
                 border_color={cx.theme().get_color("surface.base").unwrap_or_default()}
                 rounded={gpui::px(0.)}>
        <Div flex flex_col p="4">
            <Include src="ui/sections/toolbar.xml" />
            <Divider id="dvr-toolbar" />
        </Div>
        <Section><Include src="ui/sections/actions.xml" /></Section>
        <Section><Include src="ui/sections/display.xml" /></Section>
        <Section><Include src="ui/sections/surfaces.xml" /></Section>
        <Section><Include src="ui/sections/inputs.xml" /></Section>
        <Section><Include src="ui/sections/controls.xml" /></Section>
        <Section><Include src="ui/sections/overlays.xml" /></Section>
        <Section><Include src="ui/sections/lists.xml" /></Section>
        <Section><Include src="ui/sections/footer.xml" /></Section>
    </VirtualList>
</Fragment>
