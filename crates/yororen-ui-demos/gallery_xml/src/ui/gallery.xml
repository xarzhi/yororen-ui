<!--
  Gallery XML — layout in pure XML, business logic in
  the Rust `Controller`. Every `on_click={controller.foo}`
  reference resolves to a method on the controller; the
  macro's auto-wrap inlines a pre-cloned receiver so
  the same controller can drive many handlers.

  Features demonstrated (in order of appearance):
    - Containers: <Column>, <Row>, <Div> with shorthand
      style attrs (flex, flex_1, gap, items_center, ...)
    - Leaves: <Label>, <Button> (with `variant`),
      <Switch>, <Checkbox>, <TextInput>, <NumberInput>,
      <Tag>, <Progress>, <Icon>, <Avatar>, <Skeleton>
    - String interpolation: text="Count: {n}"
    - Brace expressions: on_click={controller.bump_progress}
    - Two-way binding: @bind={entity}
    - <If> / <ElseIf> / <Else> control flow
    - <Match on={...}> with <Case pattern="..."> arms
    - <State name="x" default={expr}> for local Entity
    - <For each={...} let:item key={...}> with per-row
      @bind and per-row dynamic id
    - <Template name="X"> + <Slot name="..."> for the
      reusable Card component
    - <Include src="section.xml"> for splitting the
      layout across multiple files
    - Event modifier .stop on a button to test the
      propagation control
    - Runtime-registered custom tag <CounterWidget/>

  Identifiers referenced here are bound in `src/view.rs`.
-->
<Column flex col p="4" gap="4">

    <!-- =================== Toolbar =================== -->
    <Row flex items_center gap="3">
        <Label id="title" text="yororen-ui Gallery (XML)" strong />
        <Label id="subtitle" text="All layout in XML, all logic in Rust" muted />
    </Row>

    <Row flex items_center gap="2">
        <!-- Section routing: <Match on={section}> highlights
             the button whose <Case> matches the current
             section. -->
        <Match on={section}>
            <Case pattern={crate::state::Section::Actions}>
                <Button id="r-actions" caption="Actions" variant="primary"
                        on_click={controller.goto(crate::state::Section::Actions)} />
            </Case>
            <Case pattern={crate::state::Section::Display}>
                <Button id="r-actions" caption="Actions" variant="neutral"
                        on_click={controller.goto(crate::state::Section::Actions)} />
            </Case>
            <Case pattern={crate::state::Section::Inputs}>
                <Button id="r-actions" caption="Actions" variant="neutral"
                        on_click={controller.goto(crate::state::Section::Actions)} />
            </Case>
            <Case pattern={crate::state::Section::Controls}>
                <Button id="r-actions" caption="Actions" variant="neutral"
                        on_click={controller.goto(crate::state::Section::Actions)} />
            </Case>
            <Case pattern={crate::state::Section::Lists}>
                <Button id="r-actions" caption="Actions" variant="neutral"
                        on_click={controller.goto(crate::state::Section::Actions)} />
            </Case>
        </Match>

        <Button id="r-display" caption="Display"
                on_click={controller.goto(crate::state::Section::Display)} />
        <Button id="r-inputs" caption="Inputs"
                on_click={controller.goto(crate::state::Section::Inputs)} />
        <Button id="r-controls" caption="Controls"
                on_click={controller.goto(crate::state::Section::Controls)} />
        <Button id="r-lists" caption="Lists"
                on_click={controller.goto(crate::state::Section::Lists)} />

        <Div flex_1 />

        <Label id="toast-counter" text="Toasts: {toast_count}" muted />

        <Button id="show-toast" caption="Show toast"
                on_click={controller.show_toast} />
        <Button id="show-notification" caption="Show notification"
                variant="primary"
                on_click={controller.show_notification} />
    </Row>

    <!-- =================== Actions section =================== -->
    <Column flex col gap="2">
        <Label id="actions-title" text="Actions" strong />
        <Row flex items_center gap="3">
            <Button id="btn-primary" caption="Primary"
                    variant="primary"
                    on_click={controller.bump_progress} />
            <Button id="btn-danger" caption="Danger"
                    variant="danger"
                    on_click.stop={controller.show_toast} />
            <Button id="btn-disabled" caption="Disabled" disabled="true" />
        </Row>
        <Row flex items_center gap="3">
            <Switch id="toggle-btn" @bind={toggle_btn_entity} />
            <Label id="toggle-label"
                   text={if toggle_btn { "Toggle: ON" } else { "Toggle: OFF" }} />
            <Button id="press-toggle" caption="Press me"
                    on_click={controller.press_toggle} />
            <Label id="last-action" text={"Last: ".to_string() + &last_action} muted />
        </Row>
    </Column>

    <!-- =================== Display section =================== -->
    <Column flex col gap="2">
        <Label id="display-title" text="Display" strong />

        <Row flex items_center gap="3">
            <Label id="progress-label" text="Progress" />
            <Div flex_1>
                <Progress id="progress" value={progress} />
            </Div>
            <Button id="bump-progress" caption="+10%"
                    on_click={controller.bump_progress} />
            <Button id="reset-progress" caption="Reset"
                    on_click={controller.reset_progress} />
        </Row>

        <Row flex items_center gap="3">
            <Label id="tag-label" text="Closable tag" />
            <Tag id="closable-tag" label="Click to close" />
            <Label id="tag-count" text={"x ".to_string() + &tag_close_count.to_string()} muted />
        </Row>

        <!-- Reusable Card template — defined once below, called
             three times with different content. -->
        <Template name="Card">
            <Column flex col gap="1" p="3" rounded_md>
                <Slot name="title" />
                <Slot />
            </Column>
        </Template>

        <Row flex gap="3">
            <Card>
                <Slot name="title">
                    <Label id="card1-title" text="Skeleton" strong />
                </Slot>
                <Skeleton id="skel-1" />
                <Skeleton id="skel-2" />
            </Card>
            <Card>
                <Slot name="title">
                    <Label id="card2-title" text="Avatar" strong />
                </Slot>
                <Avatar id="avatar-1" name="MX" />
            </Card>
            <Card>
                <Slot name="title">
                    <Label id="card3-title" text="Custom" strong />
                </Slot>
                <CounterWidget id="counter-1" />
            </Card>
        </Row>
    </Column>

    <!-- =================== Inputs section =================== -->
    <Column flex col gap="2">
        <Label id="inputs-title" text="Inputs" strong />

        <Row flex items_center gap="2">
            <Label id="text-label" text="TextInput" />
            <TextInput id="text-input" placeholder="Type here…"
                       @bind={text_entity} />
            <Label id="text-value" text={" = ".to_string() + &text_value} muted />
        </Row>

        <Row flex items_center gap="2">
            <Label id="search-label" text="Search" />
            <TextInput id="search-input" placeholder="Search…"
                       @bind={search_entity} />
        </Row>

        <Row flex items_center gap="2">
            <Label id="number-label" text="Number" />
            <NumberInput id="number-input" @bind={number_entity} />
            <Label id="number-value" text={" = ".to_string() + &number_value.to_string()} muted />
        </Row>
    </Column>

    <!-- =================== Controls section =================== -->
    <Column flex col gap="2">
        <Label id="controls-title" text="Controls" strong />

        <Row flex items_center gap="2">
            <Label id="checkbox-label" text="Checkbox" />
            <Checkbox id="checkbox" @bind={checkbox_entity} />
            <Label id="checkbox-value" text={if checkbox { "✓" } else { "✗" }} />
        </Row>

        <Row flex items_center gap="2">
            <Label id="switch-label" text="Switch" />
            <Switch id="switch" @bind={switch_entity} />
        </Row>

        <!-- Radio (single button — the state.radio_value
             tracks which is "checked"; switching the
             button's checked attribute in the controller
             would normally be a callback). For Phase 2
             we demo a single Radio bound to checkbox_value
             — see Checkbox above for the standard pattern. -->
        <Row flex items_center gap="2">
            <Label id="radio-label" text="Radio" />
            <Radio id="radio-0" checked={radio == 0} />
            <Radio id="radio-1" checked={radio == 1} />
            <Radio id="radio-2" checked={radio == 2} />
            <Label id="radio-value"
                   text={format!("Selected: {}", radio)} muted />
        </Row>

        <Row flex items_center gap="2">
            <Label id="slider-label" text="Slider" />
            <Slider id="slider" value={slider}
                    @bind={slider_entity} />
            <Label id="slider-value" text={slider.to_string()} muted />
        </Row>
    </Column>

    <!-- =================== Lists section =================== -->
    <Column flex col gap="2">
        <Label id="lists-title" text="Lists" strong />

        <!-- Per-row @bind: each todo has its own `done` entity so
             two checkboxes in different rows never sync. The
             keyed For gives each row a stable id so reorders
             preserve focus + internal state. -->
        <For each={todos} let:item let:index={i} key={i}>
            <Row flex items_center gap="2">
                <Checkbox id={format!("todo_{}", i)} @bind={item.done} />
                <Label id={format!("todo_label_{}", i)} text={item.label.clone()} />
            </Row>
        </For>

        <Label id="todo-summary" text={format!("{} todos", todos.len())} muted />
    </Column>

    <!-- =================== Footer =================== -->
    <Row flex items_center gap="2">
        <Label id="footer-toast" text={format!("Toasts: {}", toast_count)} muted />
        <Label id="footer-text" text={format!("Text: {}", text_value)} muted />
        <Label id="footer-switch"
               text={format!("Switch: {}", if switch { "on" } else { "off" })} muted />
        <Label id="footer-slider"
               text={format!("Slider: {:.2}", slider)} muted />
    </Row>

</Column>
