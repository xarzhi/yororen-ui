<!-- Toolbar: localized title, renderer/theme/locale toggles, toasts. -->
<Column flex col gap="md">
    <Row items="center" gap="md">
        <Heading id="title" level="H1" text={t!(cx, "demo.title")} />
        <Label id="xml-badge" text="(XML)" muted />
    </Row>

    <Wrap items="center" gap="sm">
        <ToggleButton id="renderer-default" caption={t!(cx, "demo.renderer_default")}
                      selected={controller.snapshot(cx).current_renderer == crate::state::RendererKind::Default}
                      variant="primary"
                      on_toggle={controller.select_default_renderer} />
        <ToggleButton id="renderer-brutalism" caption={t!(cx, "demo.renderer_brutalism")}
                      selected={controller.snapshot(cx).current_renderer == crate::state::RendererKind::Brutalism}
                      variant="primary"
                      on_toggle={controller.select_brutalism_renderer} />

        <ToggleButton id="dark-light" caption={t!(cx, "demo.theme_light")}
                      selected={controller.snapshot(cx).dark_mode == crate::state::DarkMode::Light}
                      on_toggle={controller.select_light_theme} />
        <ToggleButton id="dark-dark" caption={t!(cx, "demo.theme_dark")}
                      selected={controller.snapshot(cx).dark_mode == crate::state::DarkMode::Dark}
                      on_toggle={controller.select_dark_theme} />

        <ToggleButton id="locale-en" caption="EN"
                      selected={controller.snapshot(cx).current_locale == crate::state::LocaleChoice::En}
                      on_toggle={controller.select_english_locale} />
        <ToggleButton id="locale-zh" caption="中文"
                      selected={controller.snapshot(cx).current_locale == crate::state::LocaleChoice::ZhCn}
                      on_toggle={controller.select_chinese_locale} />
        <ToggleButton id="locale-ar" caption="العربية"
                      selected={controller.snapshot(cx).current_locale == crate::state::LocaleChoice::Ar}
                      on_toggle={controller.select_arabic_locale} />

        <Div flex_1 />

        <Button id="show-toast" caption={t!(cx, "demo.show_toast")}
                variant="danger"
                on_click={controller.show_toast} />
        <Button id="show-notification" caption={t!(cx, "demo.show_notification")}
                variant="primary"
                on_click={controller.show_notification} />
    </Wrap>
</Column>
