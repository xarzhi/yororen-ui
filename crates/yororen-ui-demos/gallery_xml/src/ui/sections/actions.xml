<!-- Section 1 — Actions. -->
<Column flex col gap="4">
    <Heading id="actions-title" level="H2" text={t!(cx, "demo.section_actions")} />

    <Row flex row flex_wrap items_center gap="3">
        <Cell>
            <Slot name="label"><Label id="lbl-btn-neutral" text={t!(cx, "demo.actions.cell_button_neutral")} muted /></Slot>
            <Button id="btn-neutral" caption={t!(cx, "button.neutral")} variant="neutral"
                    on_click={controller.noop_click} />
        </Cell>
        <Cell>
            <Slot name="label"><Label id="lbl-btn-primary" text={t!(cx, "demo.actions.cell_button_primary")} muted /></Slot>
            <Button id="btn-primary" caption={t!(cx, "button.primary")} variant="primary"
                    on_click={controller.noop_click} />
        </Cell>
        <Cell>
            <Slot name="label"><Label id="lbl-btn-danger" text={t!(cx, "demo.actions.cell_button_danger")} muted /></Slot>
            <Button id="btn-danger" caption={t!(cx, "button.danger")} variant="danger"
                    on_click={controller.noop_click} />
        </Cell>
        <Cell>
            <Slot name="label"><Label id="lbl-btn-disabled" text={t!(cx, "demo.actions.cell_button_disabled")} muted /></Slot>
            <Button id="btn-disabled" caption={t!(cx, "button.disabled")} disabled
                    on_click={controller.noop_click} />
        </Cell>
    </Row>

    <Row flex row flex_wrap items_center gap="3">
        <Cell>
            <Slot name="label"><Label id="lbl-icon-btn" text={t!(cx, "demo.actions.cell_icon_button")} muted /></Slot>
            <IconButton id="icon-btn-check" icon="check"
                        on_click={controller.noop_click} />
        </Cell>
        <Cell>
            <Slot name="label"><Label id="lbl-icon-btn-primary" text={t!(cx, "demo.actions.cell_icon_button_primary")} muted /></Slot>
            <IconButton id="icon-btn-primary-check" icon="check"
                        variant="primary" on_click={controller.noop_click} />
        </Cell>
    </Row>

    <Row flex row flex_wrap items_center gap="3">
        <Cell>
            <Slot name="label"><Label id="lbl-toggle" text={t!(cx, "demo.actions.cell_toggle_button")} muted /></Slot>
            <ToggleButton id="toggle-1" caption={t!(cx, "demo.actions.press_me")}
                          selected={controller.toggle_btn_selected(cx)}
                          on_toggle={controller.press_toggle_from_event} />
        </Cell>
    </Row>

    <Row flex row flex_wrap items_center gap="3">
        <Cell>
            <Slot name="label"><Label id="lbl-split" text={t!(cx, "demo.actions.cell_split_button")} muted /></Slot>
            <SplitButton id="split-1" primary={controller.split_button_primary}
                         caption={t!(cx, "demo.actions.save")}
                         state={controller.split_button_state(cx)}
                         items={controller.split_button_items(cx)}
                         on_select={controller.split_button_select} />
        </Cell>
    </Row>

    <Row flex row flex_wrap items_center gap="3">
        <Cell>
            <Slot name="label"><Label id="lbl-group" text={t!(cx, "demo.actions.cell_button_group")} muted /></Slot>
            <ButtonGroup id="btn-group-1">
                <Button id="bg-left" caption={t!(cx, "demo.actions.left")} variant="neutral"
                        on_click={controller.noop_click} />
                <Button id="bg-mid" caption={t!(cx, "demo.actions.mid")} variant="neutral"
                        on_click={controller.noop_click} />
                <Button id="bg-right" caption={t!(cx, "demo.actions.right")} variant="neutral"
                        on_click={controller.noop_click} />
            </ButtonGroup>
        </Cell>
    </Row>
</Column>
