<!--
  Showcase XML â€” exercises every Phase 1+2+3 feature
  of the `xml!` macro:

  * Containers: `<Column>`, `<Row>` with shorthand
    style attrs (flex / col / items_center / gap).
  * Leaves: `<Label>`, `<Button>`, `<Checkbox>`,
    `<Switch>`, `<TextInput>`, `<Heading>`.
  * Data binding: brace expressions for both reads
    (`{counter.to_string()}`) and event handlers.
  * Two-way binding: `@bind={entity}` on `<Switch>`,
    `<TextInput>`, and `<Checkbox>`.
  * String interpolation:
    `<Label text="Count: {counter}" />` expands to
    a `format!` call at codegen time.
  * Control flow:
    - `<If condition={flag}>` / `<ElseIf>` / `<Else>`
    - `<For each={todos} let:item>` (with `let:index`
      implicit)
    - `<Match on={...}><Case pattern={...}>...</Case></Match>`
  * Local state declaration:
    `<State name="x" default="0">â€¦</State>`
  * Custom runtime component: `<CustomWidget id="â€¦" />`
    via `register_xml_component!`.

  All of the variables referenced here (`counter`,
  `flag`, `name`, `todos`, `connection`, `inc`,
  `dec`, `reset`, `flag_entity`, `name_entity`,
  `connect_entity`) are bound in the surrounding
  Rust scope â€” see `src/view.rs`.
-->
<Column flex col p="4" gap="4">

    <!-- Heading + intro -->
    <Label id="title" text="yororen-ui XML Showcase" strong />
    <Label id="subtitle" text="Phase 1 + 2 + 3 features, all in XML" muted />

    <!-- Counter: read + button-driven mutations -->
    <Row flex gap="2" items_center>
        <Label id="count" text="Count: {counter}" strong />
        <Button id="dec" caption="-" on_click={move |_, _, cx| {
            dec.update(cx, |c, cx| { c.value -= 1; cx.notify(); });
        }} />
        <Button id="reset" caption="Reset" on_click={move |_, _, cx| {
            reset.update(cx, |c, cx| { c.value = 0; cx.notify(); });
        }} />
        <Button id="inc" caption="+" variant="primary" on_click={move |_, _, cx| {
            inc.update(cx, |c, cx| { c.value += 1; cx.notify(); });
        }} />
    </Row>

    <!-- Two-way binding: @bind on a Switch, Checkbox -->
    <Column flex col gap="2">
        <Label id="features_label" text="Two-way bindings" strong />
        <Switch id="notifications" @bind={flag_entity} />
        <Checkbox id="agree" @bind={flag_entity} />
    </Column>

    <!-- If/ElseIf/Else: chain control flow -->
    <Column flex col gap="1">
        <If condition={flag}>
            <Label id="on" text="Notifications ON" strong />
        </If>
        <ElseIf condition={!flag}>
            <Label id="off" text="Notifications OFF" muted />
        </ElseIf>
        <Else>
            <Label id="unknown" text="â€”" />
        </Else>
    </Column>

    <!-- Match/Case: pattern-match on a status enum -->
    <Column flex col gap="1">
        <Label id="match_label" text="Match / Case" strong />
        <Match on={connection}>
            <Case pattern={crate::state::ConnectionStatus::Disconnected}>
                <Label id="conn_off" text="Status: disconnected" muted />
            </Case>
            <Case pattern={crate::state::ConnectionStatus::Connecting}>
                <Label id="conn_link" text="Status: connecting..." strong />
            </Case>
            <Case pattern={crate::state::ConnectionStatus::Connected}>
                <Label id="conn_ok" text="Status: connected" strong />
            </Case>
            <Case pattern={crate::state::ConnectionStatus::Failed}>
                <Label id="conn_err" text="Status: failed" muted />
            </Case>
        </Match>
        <Button id="conn_toggle" caption="Toggle connection" on_click={move |_, _, cx| {
            connect_entity.update(cx, |c, cx| {
                *c = match *c {
                    crate::state::ConnectionStatus::Disconnected => crate::state::ConnectionStatus::Connecting,
                    crate::state::ConnectionStatus::Connecting => crate::state::ConnectionStatus::Connected,
                    crate::state::ConnectionStatus::Connected => crate::state::ConnectionStatus::Failed,
                    crate::state::ConnectionStatus::Failed => crate::state::ConnectionStatus::Disconnected,
                };
                cx.notify();
            });
        }} />
    </Column>

    <!-- For: list rendering with let:item and let:index -->
    <Column flex col gap="1">
        <Label id="todos_label" text="Todos" strong />
        <For each={todos} let:item>
            <Row flex gap="2" items_center>
                <Checkbox id="todo" @bind={flag_entity} />
                <Label id="todo_label" text={item.label} />
            </Row>
        </For>
    </Column>

    <!-- State: declare a local Entity<T> inside the closure.
         `count` shadows the surrounding counter â€” local
         scope is independent of the outer state. -->
    <Column flex col gap="1">
        <Label id="state_label" text="State: local entity" strong />
        <State name="count" default="42">
            <Label id="state_value" text={count.read(cx).to_string()} />
        </State>
    </Column>

    <!-- Custom runtime-registered widget â€” proves the
         `register_xml_component!` extension hook works. -->
    <CustomWidget id="custom" />

</Column>